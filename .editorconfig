root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Go uses tabs.
[*.go]
indent_style = tab
indent_size = 4

# Makefile-likes use tabs.
[{Makefile,*.mk,**.mk}]
indent_style = tab
indent_size = 4

# YAML / JSON / TOML: 2 spaces.
[*.{yml,yaml,json,toml}]
indent_style = space
indent_size = 2

# Markdown: trailing whitespace can be significant (line break).
[*.md]
trim_trailing_whitespace = false
